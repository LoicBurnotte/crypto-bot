# ── Kraken API ────────────────────────────────────────────────────────────────
# Permissions needed: Query Funds, Query Open Orders & Trades,
#                     Create & Modify Orders, Withdraw Funds (for /withdraw)
KRAKEN_API_KEY=your_key_here
KRAKEN_API_SECRET=your_secret_here

# ── Symbols ───────────────────────────────────────────────────────────────────
SYMBOLS=BTC/EUR,ETH/EUR,SOL/EUR,XRP/EUR,ADA/EUR,DOT/EUR,LINK/EUR,MATIC/EUR

# ── Trading ───────────────────────────────────────────────────────────────────
# EUR per auto-buy. Set to 0 for dry-run (safe default, no real orders)
TRADE_AMOUNT_EUR=0

TRAILING_STOP_PCT=0.03   # sell when price drops 3% from high
TAKE_PROFIT_PCT=0.05     # sell when price rises 5% above entry

# ── Risk management ───────────────────────────────────────────────────────────
# Stop all auto-trading if daily loss exceeds this EUR amount (0 = disabled)
MAX_DAILY_LOSS_EUR=0

# ── Indicators ────────────────────────────────────────────────────────────────
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
EMA_FAST=9
EMA_SLOW=21

# ── Notifications (Discord or Slack webhook URL) ───────────────────────────────
WEBHOOK_URL=

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-frontend.vercel.app
