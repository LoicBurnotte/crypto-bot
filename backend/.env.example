# ── Kraken API ────────────────────────────────────────────────────────────────
# Get from: https://www.kraken.com/u/security/api
# Required permissions: Query Funds, Query Open Orders & Trades, Create & Modify Orders
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# ── Trading config ────────────────────────────────────────────────────────────
# Comma-separated list of pairs to track
SYMBOLS=BTC/EUR,ETH/EUR,SOL/EUR,XRP/EUR,ADA/EUR,DOT/EUR,LINK/EUR

# EUR amount to spend per automatic buy trade
# Set to 0 for dry-run mode (no real orders placed — safe for testing)
TRADE_AMOUNT_EUR=0

# Trailing stop-loss percentage (0.03 = 3%)
TRAILING_STOP_PCT=0.03

# RSI thresholds
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70

# EMA periods
EMA_FAST=9
EMA_SLOW=21

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated extra origins (your Vercel URL). Localhost is always allowed.
ALLOWED_ORIGINS=https://your-frontend.vercel.app
